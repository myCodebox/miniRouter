{
    "name": "mycodebox/minirouter",
    "description": "A minimal PHP router",
    "type": "library",
    "require": {
        "php": ">=8.3"
    },
    "autoload": {
        "psr-4": {
            "MyCodebox\\MiniRouter\\": "src/"
        }
    },
    "authors": [
        {
            "name": "myCodebox",
            "email": "1451800+myCodebox@users.noreply.github.com"
        }
    ],
    "minimum-stability": "stable",
    "license": "MIT",
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpunit/phpunit": "^13.0"
    },
    "scripts": {
        "phpstan": "phpstan analyse --level=8",
        "cs-fix": "php-cs-fixer fix",
        "test": "phpunit"
    }
}
